// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Report {
  id        String   @id @default(cuid())
  date      DateTime
  line      Line
  machine   String
  problem   String
  fileName  String
  filePath  String
  fileSize  Int
  createdAt DateTime @default(now())

  @@map("reports")
}

enum Line {
  MEL_POUR_ANALYS
  MOULD_RCS
  CORE_MAKING
  FINISHING
  MAINTENANCE
  DIE_PRESS
}
